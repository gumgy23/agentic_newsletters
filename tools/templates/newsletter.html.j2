<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="x-apple-disable-message-reformatting">
  <title>{{ title }}</title>
  <!--[if mso]>
  <noscript>
    <xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml>
  </noscript>
  <![endif]-->
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@700&family=Inter:wght@400;600;700&display=swap');
    body { margin: 0; padding: 0; background-color: #F4F5F5; }
    table { border-collapse: collapse; }
    img { border: 0; display: block; }
    a { text-decoration: none; }
    @media only screen and (max-width: 620px) {
      .outer-table { width: 100% !important; }
      .content-cell { padding: 24px 16px !important; }
      .hero-cell { padding: 32px 16px 40px !important; }
      .header-cell { padding: 20px 16px !important; }
      .title-text { font-size: 22px !important; }
      .chart-img { width: 100% !important; height: auto !important; }
      .btn-cell { padding: 12px 24px !important; }
    }
  </style>
</head>
<body style="margin:0;padding:0;background-color:#F4F5F5;font-family:'Inter',Arial,sans-serif;">

<!-- Preheader: hidden inbox preview text -->
<div style="display:none;max-height:0;overflow:hidden;mso-hide:all;font-size:1px;color:#F4F5F5;line-height:1px;">
  {{ preview_text }}&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;
</div>

<!-- Outlook centering wrapper -->
<!--[if mso]><center><table width="600" cellpadding="0" cellspacing="0"><tr><td><![endif]-->

<!-- Outer wrapper -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" class="outer-table" style="background-color:#F4F5F5;padding:32px 0;">
  <tr>
    <td align="center">

      <!-- Main card: max 600px -->
      <table role="presentation" cellpadding="0" cellspacing="0" width="600" class="outer-table"
             style="background-color:#FFFFFF;border-radius:12px;overflow:hidden;box-shadow:0 2px 16px rgba(10,46,46,0.10);">

        <!-- ═══════════════════════════════════════ -->
        <!-- HEADER BAND                            -->
        <!-- ═══════════════════════════════════════ -->
        <tr>
          <td class="header-cell" style="background-color:#0A2E2E;padding:24px 32px;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
              <tr>
                <td style="vertical-align:middle;">
                  <img src="data:image/png;base64,{{ logo_b64 }}"
                       alt="{{ newsletter_name }}" height="36"
                       style="height:36px;width:auto;display:block;">
                </td>
                <td align="right" style="vertical-align:middle;">
                  <span style="font-family:'Inter',Arial,sans-serif;font-size:11px;font-weight:700;
                               color:#00E5A0;letter-spacing:0.1em;text-transform:uppercase;">
                    ISSUE #{{ issue_number }}&nbsp;&nbsp;·&nbsp;&nbsp;{{ date_formatted }}
                  </span>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- ═══════════════════════════════════════ -->
        <!-- HERO SECTION                           -->
        <!-- ═══════════════════════════════════════ -->
        <tr>
          <td class="hero-cell" style="background-color:#0A2E2E;padding:40px 32px 48px;">
            <!-- Neon mint accent line above title -->
            <div style="width:48px;height:3px;background-color:#00E5A0;margin-bottom:20px;"></div>

            <h1 class="title-text"
                style="font-family:'Space Grotesk',Arial,sans-serif;font-size:28px;font-weight:700;
                       color:#FFFFFF;line-height:1.25;margin:0 0 24px 0;padding:0;">
              {{ title }}
            </h1>

            {% for para in intro_paragraphs %}
            <p style="font-family:'Inter',Arial,sans-serif;font-size:16px;font-weight:400;
                      color:#E0F5F5;line-height:1.7;margin:0 0 14px 0;padding:0;">
              {{ para }}
            </p>
            {% endfor %}
          </td>
        </tr>

        <!-- ═══════════════════════════════════════ -->
        <!-- CONTENT SECTIONS                       -->
        <!-- ═══════════════════════════════════════ -->
        {% for section in sections %}
        <tr>
          <td class="content-cell" style="padding:32px 32px 0 32px;">

            <!-- Section label (SECTION 01, etc.) -->
            <p style="font-family:'Inter',Arial,sans-serif;font-size:11px;font-weight:700;
                      color:#0D6E6E;letter-spacing:0.1em;text-transform:uppercase;
                      margin:0 0 8px 0;padding:0;">
              {{ "SECTION %02d"|format(loop.index) }}
            </p>

            <!-- Section heading -->
            <h2 style="font-family:'Inter',Arial,sans-serif;font-size:20px;font-weight:600;
                       color:#111818;line-height:1.3;margin:0 0 16px 0;padding:0;">
              {{ section.heading }}
            </h2>

            <!-- Section body — split on newlines into paragraphs -->
            {% for para in section.body_paragraphs %}
            <p style="font-family:'Inter',Arial,sans-serif;font-size:16px;font-weight:400;
                      color:#374141;line-height:1.7;margin:0 0 14px 0;padding:0;">
              {{ para }}
            </p>
            {% endfor %}

            {% if section.callout %}
            <!-- Callout box -->
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
                   style="margin:20px 0 8px 0;">
              <tr>
                <td style="background-color:#E0F5F5;border-left:4px solid #0D6E6E;
                           border-radius:8px;padding:14px 18px;">
                  <p style="font-family:'Inter',Arial,sans-serif;font-size:15px;font-weight:400;
                            font-style:italic;color:#0A2E2E;line-height:1.6;margin:0;padding:0;">
                    {{ section.callout }}
                  </p>
                </td>
              </tr>
            </table>
            {% endif %}

          </td>
        </tr>

        {% if section.chart %}
        <!-- Chart injection -->
        <tr>
          <td style="padding:16px 32px 0 32px;">
            <img src="data:image/png;base64,{{ section.chart.b64 }}"
                 alt="{{ section.chart.title }}"
                 width="536" class="chart-img"
                 style="width:536px;max-width:100%;height:auto;display:block;
                        border-radius:8px;border:1px solid #D1D5D5;">
            {% if section.chart.caption %}
            <p style="font-family:'Inter',Arial,sans-serif;font-size:12px;font-weight:400;
                      color:#6B7272;line-height:1.5;margin:6px 0 0 0;padding:0;text-align:center;">
              {{ section.chart.caption }}
            </p>
            {% endif %}
          </td>
        </tr>
        {% endif %}

        <!-- Section divider (not after last section) -->
        {% if not loop.last %}
        <tr>
          <td style="padding:24px 32px 0 32px;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
              <tr><td style="border-top:1px solid #D1D5D5;height:1px;font-size:0;line-height:0;">&nbsp;</td></tr>
            </table>
          </td>
        </tr>
        {% endif %}

        {% endfor %}

        <!-- Charts not attached to any section (insert_after_section out of range) -->
        {% if orphan_charts %}
        <tr>
          <td style="padding:24px 32px 0 32px;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
              <tr><td style="border-top:1px solid #D1D5D5;height:1px;font-size:0;line-height:0;">&nbsp;</td></tr>
            </table>
          </td>
        </tr>
        {% for chart in orphan_charts %}
        <tr>
          <td style="padding:24px 32px 0 32px;">
            <img src="data:image/png;base64,{{ chart.b64 }}"
                 alt="{{ chart.title }}" width="536" class="chart-img"
                 style="width:536px;max-width:100%;height:auto;display:block;
                        border-radius:8px;border:1px solid #D1D5D5;">
            {% if chart.caption %}
            <p style="font-family:'Inter',Arial,sans-serif;font-size:12px;
                      color:#6B7272;margin:6px 0 0 0;text-align:center;">
              {{ chart.caption }}
            </p>
            {% endif %}
          </td>
        </tr>
        {% endfor %}
        {% endif %}

        <!-- ═══════════════════════════════════════ -->
        <!-- KEY TAKEAWAYS                          -->
        <!-- ═══════════════════════════════════════ -->
        <tr>
          <td style="padding:32px 32px 0 32px;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
                   style="background-color:#F4F5F5;border-radius:12px;">
              <tr>
                <td style="padding:24px;">
                  <p style="font-family:'Inter',Arial,sans-serif;font-size:11px;font-weight:700;
                            color:#0D6E6E;letter-spacing:0.1em;text-transform:uppercase;
                            margin:0 0 8px 0;padding:0;">
                    KEY TAKEAWAYS
                  </p>
                  <h2 style="font-family:'Inter',Arial,sans-serif;font-size:18px;font-weight:600;
                             color:#111818;margin:0 0 16px 0;padding:0;">
                    What you need to remember
                  </h2>
                  {% for item in takeaways %}
                  <table role="presentation" cellpadding="0" cellspacing="0"
                         style="margin-bottom:10px;width:100%;">
                    <tr>
                      <td width="24" style="vertical-align:top;padding-top:2px;">
                        <span style="font-family:'Inter',Arial,sans-serif;font-size:14px;
                                     color:#00E5A0;font-weight:700;">&#9632;</span>
                      </td>
                      <td style="vertical-align:top;">
                        <p style="font-family:'Inter',Arial,sans-serif;font-size:15px;font-weight:400;
                                  color:#374141;line-height:1.6;margin:0;padding:0;">
                          {{ item }}
                        </p>
                      </td>
                    </tr>
                  </table>
                  {% endfor %}
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- ═══════════════════════════════════════ -->
        <!-- CTA SECTION                            -->
        <!-- ═══════════════════════════════════════ -->
        <tr>
          <td style="padding:40px 32px;text-align:center;">
            <p style="font-family:'Inter',Arial,sans-serif;font-size:16px;font-weight:400;
                      color:#374141;line-height:1.6;margin:0 0 24px 0;padding:0;">
              {{ cta.context }}
            </p>
            <!-- Table-based button (email-safe, no <button> element) -->
            <table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 auto;">
              <tr>
                <td class="btn-cell"
                    style="background-color:#00E5A0;border-radius:999px;padding:14px 36px;">
                  <a href="{{ cta.url }}"
                     style="font-family:'Inter',Arial,sans-serif;font-size:15px;font-weight:700;
                            color:#0A2E2E;text-decoration:none;display:block;white-space:nowrap;">
                    {{ cta.text }}
                  </a>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- Divider before footer -->
        <tr>
          <td>
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
              <tr><td style="border-top:1px solid #D1D5D5;height:1px;font-size:0;line-height:0;">&nbsp;</td></tr>
            </table>
          </td>
        </tr>

        <!-- ═══════════════════════════════════════ -->
        <!-- FOOTER                                 -->
        <!-- ═══════════════════════════════════════ -->
        <tr>
          <td style="background-color:#0A2E2E;padding:32px;border-radius:0 0 12px 12px;">
            <!-- Footer logo (icon) + name -->
            <table role="presentation" cellpadding="0" cellspacing="0" style="margin-bottom:20px;">
              <tr>
                <td style="vertical-align:middle;padding-right:10px;">
                  <img src="data:image/png;base64,{{ icon_b64 }}"
                       alt="{{ newsletter_name }}" height="28"
                       style="height:28px;width:auto;display:block;">
                </td>
                <td style="vertical-align:middle;">
                  <span style="font-family:'Inter',Arial,sans-serif;font-size:14px;font-weight:600;
                               color:#FFFFFF;">
                    {{ newsletter_name }}
                  </span>
                </td>
              </tr>
            </table>

            <!-- Tagline -->
            <p style="font-family:'Inter',Arial,sans-serif;font-size:13px;font-weight:400;
                      color:#E0F5F5;line-height:1.6;margin:0 0 20px 0;padding:0;">
              Grow smarter with AI — insights for Indonesian businesses and professionals.
            </p>

            <!-- Social links -->
            <p style="font-family:'Inter',Arial,sans-serif;font-size:12px;font-weight:400;
                      color:#00E5A0;margin:0 0 20px 0;padding:0;">
              <a href="https://nexnusa.com" style="color:#00E5A0;text-decoration:none;">nexnusa.com</a>
              {% if social_links %}
              {% for link in social_links %}
              &nbsp;&nbsp;·&nbsp;&nbsp;
              <a href="{{ link.url }}" style="color:#00E5A0;text-decoration:none;">{{ link.platform }}</a>
              {% endfor %}
              {% endif %}
            </p>

            <!-- Legal footer -->
            <p style="font-family:'Inter',Arial,sans-serif;font-size:11px;font-weight:400;
                      color:#6B7272;line-height:1.6;margin:0;padding:0;">
              You're receiving this because you subscribed to {{ newsletter_name }}.<br>
              <a href="{{ unsubscribe_url }}" style="color:#6B7272;text-decoration:underline;">Unsubscribe</a>
            </p>
          </td>
        </tr>

      </table>
      <!-- /main card -->

      <!-- Bottom spacer -->
      <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
        <tr><td style="height:32px;">&nbsp;</td></tr>
      </table>

    </td>
  </tr>
</table>
<!-- /outer wrapper -->

<!--[if mso]></td></tr></table></center><![endif]-->

</body>
</html>
